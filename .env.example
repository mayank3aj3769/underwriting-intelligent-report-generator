# ---------------------------------------------------------------
# ALL THREE KEYS ARE REQUIRED
# ---------------------------------------------------------------

# Companies House API key
# Get one free at: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=your_api_key_here
# Sandbox: https://api-sandbox.company-information.service.gov.uk
# Live:    https://api.company-information.service.gov.uk
COMPANIES_HOUSE_API_URL=https://api-sandbox.company-information.service.gov.uk

# SerpAPI key (structured Google Search + News)
# Free tier: 100 searches/month — https://serpapi.com/
SERP_API_KEY=your_serpapi_key_here

# OpenAI API key (LLM for query gen + summarisation + report synthesis)
# https://platform.openai.com/
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# ---------------------------------------------------------------
# Agent behaviour (optional)
# ---------------------------------------------------------------
MAX_AGENT_ITERATIONS=8
REQUEST_TIMEOUT=30
